# === LLM Provider ===
# Options: azure-apim | openai
LLM_PROVIDER=azure-apim

# === Azure APIM (Hackathon) ===
AZURE_APIM_BASE_URL=https://apim-foundry-prod-ltts.azure-api.net
AZURE_APIM_API_KEY=your_team_key_here
AZURE_APIM_API_VERSION=2024-12-01-preview

# === Model Selection ===
# Azure APIM options: gpt-5-mini | gpt-5.2 | gpt-5.4 | codex
# OpenAI options: gpt-4o | gpt-4o-mini | gpt-3.5-turbo
LLM_MODEL=gpt-5.2

# === OpenAI Fallback (uncomment to use personal key) ===
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Relational DB — SQLite (hackathon, zero setup)
DATABASE_URL="file:./dev.db"

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# App
PORT=3001
NODE_ENV=development
